{
	"name": "vcms-barcode",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "node --import tsx scripts/check-playwright-e2e.ts && playwright test",
		"test:e2e:check": "node --import tsx scripts/check-playwright-e2e.ts",
		"test:e2e:install": "playwright install chromium",
		"deps:check": "ncu --peer --target latest --cooldown 3d",
		"deps:update": "ncu --peer --target latest --cooldown 3d -u && npm install",
		"sbom": "mkdir -p generated && cyclonedx-npm --package-lock-only --output-reproducible --output-format JSON --output-file generated/sbom.cdx.json",
		"sbom:stdout": "cyclonedx-npm --package-lock-only --output-reproducible --output-format JSON --output-file -",
		"db:start": "docker compose up -d",
		"db:push": "drizzle-kit push --force",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"qz:cert:dev": "bash scripts/generate-qz-dev-cert.sh",
		"ehrbase:smoke": "tsx scripts/ehrbase-smoke.ts",
		"seed": "tsx scripts/seed.ts"
	},
	"dependencies": {
		"@testing-library/svelte": "^5.3.1",
		"bwip-js": "^4.10.1",
		"pino": "^10.3.1",
		"smol-toml": "^1.6.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@better-auth/core": "^1.6.9",
		"@better-auth/telemetry": "^1.6.9",
		"@better-auth/utils": "^0.4.0",
		"@better-fetch/fetch": "^1.1.21",
		"@cyclonedx/cyclonedx-npm": "^4.2.1",
		"@emnapi/core": "^1.10.0",
		"@emnapi/runtime": "^1.10.0",
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@opentelemetry/api": "^1.9.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25",
		"ajv": "^8.20.0",
		"better-auth": "~1.6.9",
		"better-call": "^1.3.5",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"npm-check-updates": "^22.1.1",
		"playwright": "^1.59.1",
		"postgres": "^3.4.9",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.7",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1"
	}
}
