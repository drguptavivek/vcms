# Database
DB_HOST="localhost"
DB_PORT="5400"
DB_NAME="local"
DB_USER="root"
DB_PASSWORD="mysecretpassword"

ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="replace-with-a-32-character-local-secret"

# Local development fallback login; replace/remove before production.
DEV_LOGIN_ENABLED="true"
DEV_ADMIN_EMAIL="admin@example.test"
DEV_ADMIN_PASSWORD="ChangeMe123!"
DEV_EMR_TESTER_EMAIL="emr.tester@example.test"
DEV_EMR_TESTER_PASSWORD="ChangeMe123!"

# QZ Tray encrypted DB credential storage.
# Required to encrypt/decrypt QZ Tray certificate and private-key records saved in mas_settings.
# Generate with: openssl rand -base64 32
QZ_CREDENTIAL_ENCRYPTION_KEY="replace-with-32-byte-random-secret"

# EHRbase local openEHR CDR
EHRBASE_PORT="8080"
EHRBASE_BASE_URL="http://localhost:8080/ehrbase/rest/openehr/v1"
EHRBASE_SERVER_NODENAME="vcms.local.ehrbase"
EHRBASE_SUBJECT_NAMESPACE="vcms-patient"
EHRBASE_DEFAULT_TEMPLATE_ID=""
EHRBASE_DEFAULT_COMPOSITION_PREFIX=""
EHRBASE_DB_PORT="5443"
EHRBASE_POSTGRES_PASSWORD="postgres"
EHRBASE_DB_ADMIN_USER="ehrbase"
EHRBASE_DB_ADMIN_PASSWORD="ehrbase"
EHRBASE_DB_USER="ehrbase_restricted"
EHRBASE_DB_PASSWORD="ehrbase_restricted"
EHRBASE_SECURITY_AUTHTYPE="BASIC"
EHRBASE_AUTH_USER="ehrbase-user"
EHRBASE_AUTH_PASSWORD="SuperSecretPassword"
EHRBASE_ADMIN_USER="ehrbase-admin"
EHRBASE_ADMIN_PASSWORD="EvenMoreSecretPassword"
EHRBASE_ADMIN_API_ACTIVE="true"

# Clinical terminology / SNOMED CT browser integration.
# mock is for local development only. Use Snowstorm, CSNOServ, or a governed terminology service before clinical use.
TERMINOLOGY_PROVIDER="mock"
SNOMED_BROWSER_URL=""
SNOMED_EDITION="SNOMEDCT-International"
SNOMED_VERSION=""
SNOMED_LANGUAGE_REFSET=""
SNOWSTORM_BASE_URL=""
SNOWSTORM_BRANCH="MAIN"
CSNOSERV_BASE_URL=""
