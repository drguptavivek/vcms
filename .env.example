# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="replace-with-a-32-character-local-secret"

# Local development fallback login; replace/remove before production.
DEV_LOGIN_ENABLED="true"
DEV_ADMIN_EMAIL="admin@example.test"
DEV_ADMIN_PASSWORD="ChangeMe123!"
